# Copy to `.env` on the host and fill in real values. `.env` is git-ignored and
# must stay that way — it holds the CalDAV app-specific password. Nothing secret
# is baked into the image; credentials are injected at runtime.

# --- Image / deploy (read by docker-compose.yml) ---
IMAGE=ghcr.io/jb09/caldav-mcp-wrapper:latest
CONTAINER_NAME=caldav-mcp
# External Docker network shared with your authorization proxy (e.g. Pomerium).
PROXY_NETWORK=pomerium

# --- CalDAV server (defaults target Apple iCloud) ---
CALDAV_URL=https://caldav.icloud.com/
# For iCloud this is your Apple ID (full email address).
CALDAV_USERNAME=you@example.com
# iCloud App-Specific Password (Apple ID -> Sign-In and Security -> App-Specific
# Passwords). This is NOT your normal Apple ID password.
CALDAV_PASSWORD=your-app-specific-password

# --- Calendar selection ---
# Default calendar (by display name) used when a tool call omits `calendar`.
DEFAULT_CALENDAR=Home
# Comma-separated allowlist of calendar display names. Tools may only read from /
# write to these, so even a misused tool cannot touch other calendars. Leave
# empty to allow every calendar in the account.
ALLOWED_CALENDARS=Home

# --- Read-only mode ---
# Set to `true` to disable the create/update/delete tools (list/get still work).
READ_ONLY=false

# --- Startup self-test ---
# Set to `true` to connect to CalDAV and list calendars when the server starts,
# verifying the configuration. On failure the reason is logged (auth / connection
# / discovery) and the server keeps running.
STARTUP_TEST=false

# --- App-layer auth (defense in depth) ---
# The external authorization proxy is ALWAYS required. Set this to `true` to ALSO
# cryptographically verify Pomerium's identity assertion on every /mcp request
# (signature + expiry + audience). This blocks anything on the shared Docker
# network from reaching the app directly, bypassing Pomerium.
#
# When true you MUST:
#   1. Set `pass_identity_headers: true` on the Pomerium route (see README) — else
#      Pomerium sends no header and every request is rejected.
#   2. Set POMERIUM_JWKS_URL and POMERIUM_AUDIENCE below.
REQUIRE_POMERIUM_IDENTITY=false
# Pomerium's JWKS endpoint (public keys for its signing key). Required when the
# gate is on; the server refuses to start without it.
# POMERIUM_JWKS_URL=https://caldav-mcp.example.com/.well-known/pomerium/jwks.json
# Expected `aud` claim — the route's host/URL. Verified when set (strongly recommended).
# POMERIUM_AUDIENCE=caldav-mcp.example.com
# Expected `iss` claim. Verified only when set.
# POMERIUM_ISSUER=
# Header(s) carrying the assertion JWT (comma-separated). Default covers MCP mode
# (x-pomerium-assertion) and the general header (x-pomerium-jwt-assertion).
# POMERIUM_IDENTITY_HEADER=x-pomerium-assertion,x-pomerium-jwt-assertion

# --- Server bind (rarely changed) ---
# HOST=0.0.0.0
# PORT=8080
